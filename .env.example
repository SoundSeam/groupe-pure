# Production defaults to homepage-only unless the full site is explicitly enabled.
FULL_SITE_ENABLED=false

# Browser key restricted to the production and local website origins.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Keep the live widget off until the key restrictions have been verified.
GOOGLE_MAPS_REVIEWS_ENABLED=false

# Groupe Pure Construction, 2100 Bd Marie-Victorin, Longueuil.
NEXT_PUBLIC_GOOGLE_MAPS_PLACE_ID=ChIJYfqnaBUdyUwRhU9gd9XSOJs

# Supabase authentication and media storage.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Supabase Postgres: transaction pooler for the app, session pooler for migrations.
DATABASE_URL=
DIRECT_URL=

# Comma-separated allowlist for the CMS and matching Supabase Storage policies.
ADMIN_EMAILS=sounds@soundseam.com

# Contact-email secrets are configured in Supabase Edge Function Secrets, not
# in the Next.js environment. See the contact form setup in README.md.
